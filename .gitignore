# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
scripts/*-output.json
scripts/push-to-remote.ts
passwords.txt
players_to_collect.txt
